---
import { t, localePath } from '../i18n/ui.js';
import { GUIDES } from '../data/guides.js';
const { lang = 'en' } = Astro.props;
const avail = GUIDES.filter((g) => (g.locales || ['en']).includes(lang) && g.day).sort((a, b) => a.day - b.day);
const blurb = {
  en: 'A calendar of the modern web platform. Behind each door: a tested, runnable guide to an HTML, CSS, JavaScript or Web API feature. New doors open as the series grows.',
  fr: 'Un calendrier de la plateforme web moderne. Derrière chaque porte : un guide testé et exécutable sur une fonctionnalité HTML, CSS, JavaScript ou Web API. De nouvelles portes s’ouvrent au fil de la série.',
  es: 'Un calendario de la plataforma web moderna. Tras cada puerta: una guía probada y ejecutable sobre una función de HTML, CSS, JavaScript o Web API. Se abren nuevas puertas a medida que crece la serie.',
  de: 'Ein Kalender der modernen Web-Plattform. Hinter jeder Tür: eine getestete, lauffähige Anleitung zu einem HTML-, CSS-, JavaScript- oder Web-API-Feature. Neue Türen öffnen sich, während die Serie wächst.',
  it: 'Un calendario della piattaforma web moderna. Dietro ogni porta: una guida testata ed eseguibile su una funzionalità HTML, CSS, JavaScript o Web API. Nuove porte si aprono man mano che la serie cresce.',
  pt: 'Um calendário da plataforma web moderna. Atrás de cada porta: um guia testado e executável sobre um recurso de HTML, CSS, JavaScript ou Web API. Novas portas abrem à medida que a série cresce.',
}[lang];
const soonNote = {
  en: 'More doors opening soon.', fr: 'D’autres portes bientôt.', es: 'Pronto más puertas.',
  de: 'Bald öffnen weitere Türen.', it: 'Presto altre porte.', pt: 'Em breve mais portas.',
}[lang];
---
<section class="advent-page">
  <p class="kicker">✦ {t(lang, 'advent')}</p>
  <h1>Web Platform Advent</h1>
  <p class="blurb">{blurb}</p>

  <ul class="doors">
    {avail.map((g) => (
      <li class="door">
        <a href={localePath(lang, `guides/${g.slug}`)}>
          <span class="door__top">
            <span class="door__num">{g.day}</span>
            <span class="door__cat">{g.cat}</span>
          </span>
          <span class="door__title">{g.title[lang] || g.title.en}</span>
          <span class="door__more">{t(lang, 'readMore')} →</span>
        </a>
      </li>
    ))}
  </ul>
  <p class="soon">{soonNote}</p>
</section>

<style>
  .advent-page { max-width: 1000px; margin: 0 auto; }
  .kicker { font-family: var(--mono); color: var(--accent-amber); font-size: .85rem; margin: 0 0 .5rem; }
  h1 { font-size: clamp(2.2rem, 5vw, 3.2rem); margin: 0; }
  .blurb { color: var(--muted); max-width: 64ch; margin: 1rem 0 0; }

  .doors { list-style: none; padding: 0; margin: 2.5rem 0 0; display: grid; gap: 1rem;
    grid-template-columns: repeat(auto-fill, minmax(230px, 1fr)); }
  .door { border: 1px solid var(--line); border-radius: 14px;
    background: linear-gradient(155deg, rgba(245,165,36,.07), rgba(77,141,255,.05)), var(--surface);
    transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease; }
  .door:hover { transform: translateY(-4px); border-color: var(--accent-amber);
    box-shadow: 0 18px 40px -22px rgba(245,165,36,.6); }
  .door a { display: flex; flex-direction: column; gap: .6rem; height: 100%; padding: 1.1rem 1.2rem; text-decoration: none; }
  .door__top { display: flex; align-items: center; gap: .6rem; }
  .door__num { display: grid; place-items: center; width: 2rem; height: 2rem; flex: none;
    font-family: var(--display); font-weight: 700; font-size: 1.05rem; color: #1a1205;
    background: var(--accent-amber); border-radius: 8px; }
  .door__cat { font-family: var(--mono); font-size: .66rem; color: var(--accent-blue); text-transform: uppercase; letter-spacing: .07em; }
  .door__title { font-family: var(--display); font-weight: 600; font-size: 1.05rem; line-height: 1.2; color: var(--ink); }
  .door__more { margin-top: auto; font-family: var(--mono); font-size: .8rem; color: var(--accent-amber); }
  .soon { margin: 2rem 0 0; color: var(--muted); font-family: var(--mono); font-size: .85rem; }
</style>
