---
import { t, localePath, UI } from '../i18n/ui.js';
import { GUIDES } from '../data/guides.js';
const { lang = 'en' } = Astro.props;
const avail = GUIDES.filter((g) => (g.locales || ['en']).includes(lang));

// Group by category, in editorial order
const CATS = [
  { key: 'js',      label: { en: 'JavaScript', fr: 'JavaScript', es: 'JavaScript', de: 'JavaScript', it: 'JavaScript', pt: 'JavaScript' } },
  { key: 'css',     label: { en: 'CSS', fr: 'CSS', es: 'CSS', de: 'CSS', it: 'CSS', pt: 'CSS' } },
  { key: 'apis',    label: { en: 'Web APIs', fr: 'Web APIs', es: 'Web APIs', de: 'Web-APIs', it: 'Web API', pt: 'Web APIs' } },
  { key: 'html',    label: { en: 'HTML', fr: 'HTML', es: 'HTML', de: 'HTML', it: 'HTML', pt: 'HTML' } },
  { key: 'hosting', label: { en: 'Hosting & deploy', fr: 'Hébergement', es: 'Alojamiento', de: 'Hosting', it: 'Hosting', pt: 'Hospedagem' } },
];
const groups = CATS.map((c) => ({ ...c, items: avail.filter((g) => g.cat === c.key) })).filter((c) => c.items.length);
const adventCount = avail.length;
const adventLabel = { en: 'See the calendar', fr: 'Voir le calendrier', es: 'Ver el calendario', de: 'Zum Kalender', it: 'Vedi il calendario', pt: 'Ver o calendário' }[lang];
const adventBlurb = {
  en: `An advent-style calendar of the web platform - ${adventCount} runnable demos and deep-dives, one door at a time.`,
  fr: `Un calendrier de l’avent de la plateforme web - ${adventCount} démos et plongées exécutables, une porte à la fois.`,
  es: `Un calendario de adviento de la plataforma web - ${adventCount} demos y análisis ejecutables, una puerta a la vez.`,
  de: `Ein Adventskalender der Web-Plattform - ${adventCount} lauffähige Demos und Deep-Dives, ein Türchen nach dem anderen.`,
  it: `Un calendario dell’avvento della piattaforma web - ${adventCount} demo e approfondimenti eseguibili, una casella alla volta.`,
  pt: `Um calendário do advento da plataforma web - ${adventCount} demos e análises executáveis, uma porta de cada vez.`,
}[lang];
---
<section class="hero">
  <div class="hero__text">
    <p class="kicker">&lt;/&gt; html5advent.com · est. 2010</p>
    <h1 class="hero__h1">The modern <span class="grad">web platform</span>, decoded.</h1>
    <p class="hero__tag">{t(lang, 'tagline')}</p>
    <p class="hero__intro">{t(lang, 'intro')}</p>
    <a class="hero__cta" href={localePath(lang, 'guides')}>{t(lang, 'guides')} →</a>
  </div>
  <pre class="hero__code" aria-hidden="true">{`const res = await fetch('/api');
const data = await res.json();

@container (min-width: 30rem) {
  .card { grid-template: …; }
}

navigator.serviceWorker
  .register('/sw.js');`}</pre>
</section>

{groups.map((group) => (
  <section class="cat">
    <div class="cat__head">
      <h2>{group.label[lang] || group.label.en}</h2>
      <span class="cat__count">{group.items.length}</span>
    </div>
    <ul class="cards">
      {group.items.map((g) => (
        <li class="card">
          <a href={localePath(lang, `guides/${g.slug}`)}>
            <span class="card__cat">{g.cat}{g.cluster ? ' · €' : ''}</span>
            <span class="card__title">{g.title[lang] || g.title.en}</span>
            <span class="card__desc">{(g.desc?.[lang] || g.desc?.en) ?? ''}</span>
            <span class="card__more">{t(lang, 'readMore')} →</span>
          </a>
        </li>
      ))}
    </ul>
  </section>
))}

<aside class="advent-teaser">
  <div>
    <p class="advent-teaser__k">✦ {t(lang, 'advent')}</p>
    <p class="advent-teaser__b">{adventBlurb}</p>
  </div>
  <a class="advent-teaser__cta" href={localePath(lang, 'advent')}>{adventLabel} →</a>
</aside>

<style>
  /* HERO */
  .hero { display: grid; grid-template-columns: 1.2fr .8fr; gap: 2.5rem; align-items: center;
    padding: 2rem 0 3.5rem; border-bottom: 1px solid var(--line); }
  .kicker { font-family: var(--mono); color: var(--accent-blue); font-size: .82rem; margin: 0 0 1rem; letter-spacing: .02em; }
  .hero__h1 { font-size: clamp(2.4rem, 5.5vw, 4rem); margin: 0; line-height: 1.04; }
  .grad { background: linear-gradient(100deg, var(--accent-amber), var(--accent-blue)); -webkit-background-clip: text; background-clip: text; color: transparent; }
  .hero__tag { font-family: var(--display); font-size: 1.25rem; color: var(--ink); margin: 1.1rem 0 0; }
  .hero__intro { color: var(--muted); margin: .9rem 0 1.6rem; max-width: 52ch; }
  .hero__cta { display: inline-block; font-family: var(--mono); font-size: .9rem; font-weight: 600;
    color: #1a1205; background: var(--accent-amber); padding: .7rem 1.3rem; border-radius: 8px; text-decoration: none;
    transition: transform .15s ease, box-shadow .15s ease; }
  .hero__cta:hover { transform: translateY(-2px); box-shadow: 0 10px 30px -10px var(--accent-amber); }
  .hero__code { margin: 0; padding: 1.4rem 1.5rem; background: #0a0c12; border: 1px solid var(--line);
    border-radius: 14px; font-family: var(--mono); font-size: .82rem; line-height: 1.7; color: #b8c2da;
    overflow: hidden; box-shadow: 0 24px 60px -30px rgba(77,141,255,.5); }

  /* CATEGORY SECTIONS */
  .cat { margin: 3rem 0 0; }
  .cat__head { display: flex; align-items: baseline; gap: .75rem; border-bottom: 1px solid var(--line); padding-bottom: .5rem; }
  .cat__head h2 { font-size: 1.5rem; margin: 0; }
  .cat__count { font-family: var(--mono); font-size: .8rem; color: var(--muted); }
  .cards { list-style: none; padding: 0; margin: 1.25rem 0 0; display: grid; gap: 1rem;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); }
  .card { border: 1px solid var(--line); border-radius: 14px; background: var(--surface);
    transition: transform .18s ease, border-color .18s ease, box-shadow .18s ease; }
  .card:hover { transform: translateY(-4px); border-color: var(--accent-blue); box-shadow: 0 18px 40px -24px rgba(77,141,255,.6); }
  .card a { display: flex; flex-direction: column; gap: .5rem; padding: 1.3rem; text-decoration: none; height: 100%; }
  .card__cat { font-family: var(--mono); font-size: .7rem; color: var(--accent-blue); text-transform: uppercase; letter-spacing: .06em; }
  .card__title { font-family: var(--display); font-weight: 600; font-size: 1.12rem; color: var(--ink); line-height: 1.2; }
  .card__desc { color: var(--muted); font-size: .9rem; line-height: 1.5; }
  .card__more { margin-top: auto; color: var(--accent-amber); font-size: .85rem; font-family: var(--mono); }

  /* ADVENT TEASER (secondary) */
  .advent-teaser { display: flex; align-items: center; justify-content: space-between; gap: 1.5rem; flex-wrap: wrap;
    margin: 3.5rem 0 1rem; padding: 1.5rem 1.75rem; border-radius: 16px;
    border: 1px solid var(--line);
    background: linear-gradient(120deg, rgba(245,165,36,.10), rgba(77,141,255,.08)); }
  .advent-teaser__k { font-family: var(--mono); color: var(--accent-amber); font-size: .85rem; margin: 0 0 .35rem; }
  .advent-teaser__b { margin: 0; color: var(--ink); max-width: 60ch; }
  .advent-teaser__cta { flex: none; font-family: var(--mono); font-size: .88rem; color: var(--accent-blue); text-decoration: none; white-space: nowrap; font-weight: 600; }
  .advent-teaser__cta:hover { text-decoration: underline; }

  @media (max-width: 780px) {
    .hero { grid-template-columns: 1fr; gap: 1.5rem; }
    .hero__code { display: none; }
  }
</style>
