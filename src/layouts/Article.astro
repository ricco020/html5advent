---
import Base from './Base.astro';
import Cta from '../components/Cta.astro';
import { t, localePath } from '../i18n/ui.js';
import { productNode, itemListNode } from '../data/products.js';
import { GUIDES } from '../data/guides.js';

const {
  title, description, lang = 'en', slug,
  cat, day, hero, heroAlt, updated = '2026-06-25',
  cluster = null,            // 'hosting' | 'deploy' → renders CTA; null = no CTA (reference)
  // Optional honest commerce schema (Product / SoftwareApplication / ItemList + Offer).
  // Shapes:
  //   { type: 'product', key: 'contabo', software: true, offers: true }  → single product/review
  //   { type: 'itemlist', name: '…', keys: ['contabo','hetzner',…] }      → comparison / best-of list
  // `offers: true` is HONEST ONLY when the price is visible in the page body (see products.js).
  commerce = null,
  // Optional FAQ: array of { q, a } - renders a visible FAQ section + FAQPage JSON-LD (GEO).
  faq = null,
} = Astro.props;

const path = `guides/${slug}`;
const url = 'https://html5advent.com' + localePath(lang, path);
const article = {
  '@type': 'TechArticle',
  headline: title,
  description,
  inLanguage: lang,
  datePublished: updated,
  dateModified: updated,
  author: { '@type': 'Organization', name: 'HTML5 Advent' },
  publisher: { '@type': 'Organization', name: 'HTML5 Advent', url: 'https://html5advent.com' },
  mainEntityOfPage: url,
  image: hero ? `https://html5advent.com${hero}` : undefined,
};

// Build honest commerce node(s) from the `commerce` prop. No rating is ever emitted.
let commerceNode = null;
if (commerce && commerce.type === 'product' && commerce.key) {
  commerceNode = productNode(commerce.key, {
    withOffers: commerce.offers === true,
    asSoftwareApplication: commerce.software === true,
  });
} else if (commerce && commerce.type === 'itemlist' && Array.isArray(commerce.keys)) {
  commerceNode = itemListNode(commerce.keys, commerce.name || title);
}

// Optional FAQPage node (GEO / rich result). Honest: only the Q&A actually shown in the page.
const faqNode = (Array.isArray(faq) && faq.length)
  ? { '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) }
  : null;

// Emit a single JSON-LD: keep TechArticle, add commerce + FAQ via @graph when present.
const graph = [article, commerceNode, faqNode].filter(Boolean);
const schema = graph.length > 1
  ? { '@context': 'https://schema.org', '@graph': graph }
  : { '@context': 'https://schema.org', ...article };

const FAQ_LABEL = { en: 'Frequently asked questions', fr: 'Questions fréquentes', es: 'Preguntas frecuentes', de: 'Häufige Fragen', it: 'Domande frequenti', pt: 'Perguntas frequentes' };

// Related guides - internal links so every guide is cross-linked (crawl paths, not a dead end).
// Same category first, then fill with others; only guides that exist in this locale (no 404s).
const REL_LABEL = { en: 'Related guides', fr: 'Guides liés', es: 'Guías relacionadas', de: 'Verwandte Guides', it: 'Guide correlate', pt: 'Guias relacionados' };
const inLang = GUIDES.filter((g) => g.slug !== slug && (g.locales || ['en']).includes(lang));
const related = [...inLang.filter((g) => g.cat === cat), ...inLang.filter((g) => g.cat !== cat)].slice(0, 4);
---
<Base title={`${title} - HTML5 Advent`} description={description} lang={lang} path={path} schema={schema} ogType="article">
  <article class="article">
    <nav class="crumb" aria-label="Breadcrumb">
      <a href={localePath(lang)}>{t(lang, 'home')}</a> ›
      <a href={localePath(lang, 'guides')}>{t(lang, 'guides')}</a> ›
      <span>{title}</span>
    </nav>

    <header class="art-head">
      <p class="kicker">// {cat}{day ? ` · ${t(lang, 'advent')} #${day}` : ''}</p>
      <h1>{title}</h1>
      <p class="lede">{description}</p>
    </header>

    {hero && <img class="hero-img" src={hero} alt={heroAlt} width="1280" height="720" loading="eager" />}

    {cluster && <Cta cluster={cluster} locale={lang} />}

    <div class="prose"><slot /></div>

    {cluster && <Cta cluster={cluster} locale={lang} />}

    {Array.isArray(faq) && faq.length > 0 && (
      <section class="faq" aria-label={FAQ_LABEL[lang] || FAQ_LABEL.en}>
        <h2>{FAQ_LABEL[lang] || FAQ_LABEL.en}</h2>
        <dl>
          {faq.map((f) => (
            <div class="faq-item">
              <dt>{f.q}</dt>
              <dd>{f.a}</dd>
            </div>
          ))}
        </dl>
      </section>
    )}

    {related.length > 0 && (
      <aside class="related" aria-label={REL_LABEL[lang] || REL_LABEL.en}>
        <h2>{REL_LABEL[lang] || REL_LABEL.en}</h2>
        <ul>
          {related.map((g) => (
            <li><a href={localePath(lang, `guides/${g.slug}`)}>{(g.title && (g.title[lang] || g.title.en)) || g.slug}</a></li>
          ))}
        </ul>
      </aside>
    )}
  </article>

  <style>
    .article { max-width: 760px; margin: 0 auto; }
    .crumb { font-family: var(--mono); font-size: .78rem; color: var(--muted); margin-bottom: 1.5rem; }
    .crumb a { color: var(--accent-blue); text-decoration: none; }
    .kicker { font-family: var(--mono); color: var(--accent-blue); font-size: .82rem; margin: 0 0 .5rem; }
    .art-head h1 { font-size: clamp(2rem, 5vw, 3rem); margin: 0; }
    .lede { color: var(--muted); font-size: 1.1rem; margin: 1rem 0 0; }
    .hero-img { width: 100%; height: auto; border-radius: 12px; margin: 2rem 0; border: 1px solid var(--line); }
    .prose { font-size: 1.02rem; }
    .prose :global(h2) { font-size: 1.6rem; margin: 2.5rem 0 .75rem; }
    .prose :global(h3) { font-size: 1.2rem; margin: 1.75rem 0 .5rem; }
    .prose :global(p) { margin: 1rem 0; }
    .prose :global(a) { color: var(--accent-blue); }
    .prose :global(ul), .prose :global(ol) { padding-left: 1.25rem; }
    .prose :global(li) { margin: .4rem 0; }
    .prose :global(pre) { background: #0a0c12; border: 1px solid var(--line); border-radius: 10px;
      padding: 1rem 1.25rem; overflow-x: auto; font-family: var(--mono); font-size: .88rem; line-height: 1.6; }
    .prose :global(code) { font-family: var(--mono); font-size: .9em; }
    .prose :global(:not(pre) > code) { background: var(--surface); padding: .1rem .35rem; border-radius: 5px; color: var(--accent-amber); }
    .prose :global(figure) { margin: 2rem 0; }
    .prose :global(figure img) { width: 100%; height: auto; border-radius: 10px; border: 1px solid var(--line); }
    .prose :global(figcaption) { color: var(--muted); font-size: .85rem; margin-top: .5rem; text-align: center; }
    .prose :global(table) { width: 100%; border-collapse: collapse; margin: 1.5rem 0; font-size: .92rem; }
    .prose :global(th), .prose :global(td) { border: 1px solid var(--line); padding: .55rem .75rem; text-align: left; }
    .prose :global(th) { background: var(--surface); font-family: var(--display); }
    .faq { max-width: 760px; margin: 3rem auto 0; padding-top: 1.5rem; border-top: 1px solid var(--line); }
    .faq h2 { font-size: 1.4rem; margin: 0 0 1rem; }
    .faq dl { margin: 0; }
    .faq-item { margin: 0 0 1.25rem; }
    .faq dt { font-weight: 600; font-size: 1.05rem; margin: 0 0 .35rem; }
    .faq dd { margin: 0; color: var(--muted); }
    .related { max-width: 760px; margin: 3rem auto 0; padding-top: 1.5rem; border-top: 1px solid var(--line); }
    .related h2 { font-size: 1.2rem; font-family: var(--mono); color: var(--accent-blue); margin: 0 0 .75rem; }
    .related ul { list-style: none; padding: 0; margin: 0; display: grid; gap: .5rem; }
    .related a { color: var(--accent-blue); text-decoration: none; }
    .related a:hover { text-decoration: underline; }
  </style>
</Base>
