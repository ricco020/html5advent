---
import Base from '../../layouts/Base.astro';
import Home from '../../components/Home.astro';
const schema = {
  '@context': 'https://schema.org', '@type': 'WebSite', name: 'HTML5 Advent',
  url: 'https://html5advent.com/es',
  description: 'Guías prácticas de la plataforma web moderna - HTML, CSS, JavaScript y Web APIs.',
  inLanguage: 'es',
};
---
<Base
  title="HTML5 Advent - guías de la plataforma web moderna, HTML/CSS/JS y Web APIs"
  description="Guías prácticas y probadas sobre HTML, CSS, JavaScript y las Web APIs del navegador, además del calendario Web Platform Advent de demos front-end."
  lang="es" path="" schema={schema}
>
  <Home lang="es" />
</Base>
